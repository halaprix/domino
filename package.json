{
  "name": "multicall-resolver",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./engines/viem": {
      "import": {
        "types": "./dist/engines/viem.d.ts",
        "default": "./dist/engines/viem.js"
      },
      "require": {
        "types": "./dist/engines/viem.d.cts",
        "default": "./dist/engines/viem.cjs"
      }
    },
    "./engines/ethers-v6": {
      "import": {
        "types": "./dist/engines/ethers-v6.d.ts",
        "default": "./dist/engines/ethers-v6.js"
      },
      "require": {
        "types": "./dist/engines/ethers-v6.d.cts",
        "default": "./dist/engines/ethers-v6.cjs"
      }
    },
    "./engines/ethers-v5": {
      "import": {
        "types": "./dist/engines/ethers-v5.d.ts",
        "default": "./dist/engines/ethers-v5.js"
      },
      "require": {
        "types": "./dist/engines/ethers-v5.d.cts",
        "default": "./dist/engines/ethers-v5.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "peerDependencies": {
    "ethers": "^5.0.0 || ^6.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "ethers": "^6.0.0",
    "ethers-v5": "npm:ethers@^5.0.0",
    "prettier": "^3.8.3",
    "tsup": "^8.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "viem": "^2.39.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ethereum",
    "multicall",
    "evm",
    "viem",
    "ethers",
    "blockchain",
    "rpc",
    "batch"
  ],
  "repository": {
    "type": "git",
    "url": "TODO: add repo URL after creation"
  }
}
