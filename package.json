{
  "name": "@halaprix/domino",
  "version": "2.0.0",
  "private": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "description": "Sequential, self-triggering on-chain reads. FSM executor for Multicall3 — reduces N×M RPC calls to M multicalls.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/halaprix/domino#readme",
  "bugs": {
    "url": "https://github.com/halaprix/domino/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup && node scripts/postbuild.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:live": "tsx scripts/benchmark-live.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "ethers": "^5.8.0 || ^6.16.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "ethers": "6.16.0",
    "ethers-v5": "npm:ethers@5.8.0",
    "prettier": "^3.8.3",
    "tsup": "^8.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ethereum",
    "multicall",
    "evm",
    "viem",
    "ethers",
    "blockchain",
    "rpc",
    "batch",
    "sequential",
    "domino"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/halaprix/domino"
  },
  "dependencies": {
    "abitype": "^1.2.4",
    "viem": "^2.52.0"
  }
}
